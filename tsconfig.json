{
  "ts-node": {
    "require": [
      "tsconfig-paths/register"
    ],
    "transpileOnly": true
  },
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": false,
    "module": "commonjs",
    "rootDir": "src",
    "outDir": "./dist",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "typeRoots": [
      "./node_modules/@types"
    ],
  },
  "include": [
    "src/**/*"
  ]
}